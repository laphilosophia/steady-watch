  "repository": {
    "type": "git",
    "url": "git+https://github.com/laphilosophia/steady-watch.git"
  },
  "bugs": {
    "url": "https://github.com/laphilosophia/steady-watch/issues"
  },
  "homepage": "https://github.com/laphilosophia/steady-watch#readme",
  "type": "commonjs",
  "dependencies": {
    "chalk": "^5.6.2",
    "chokidar": "^3.6.0",
    "commander": "^14.0.2"
  },
  "devDependencies": {
    "@types/node": "^25.0.8",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
